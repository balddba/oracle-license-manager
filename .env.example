# Default: SQLite (see config/license-tracker.yaml). No secrets required for local dev.
# LICENSE_TRACKER_CONFIG_PATH=config/license-tracker.yaml
# LICENSE_TRACKER_SQLITE_PATH=data/db/license_tracker.db
# LICENSE_TRACKER_SQLITE_HOST_PATH=./data/db


# Oracle (set database_backend: oracle in config/license-tracker.yaml)
# LICENSE_TRACKER_ORACLE_PASSWORD=your_password

# PostgreSQL (set database_backend: postgresql in YAML)
# LICENSE_TRACKER_POSTGRESQL_PASSWORD=your_password

# CORS (comma-separated origins override via env if needed)
# LICENSE_TRACKER_CORS_ORIGINS=["http://localhost:5173"]
